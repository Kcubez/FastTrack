// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ─── Better Auth Required Tables ────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String    @default("user") // "user" | "admin"
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  geminiApiKey  String?   // Per-user Gemini API key (stored encrypted-at-rest by Supabase)

  sessions Session[]
  accounts Account[]
  contents Content[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── FastTrack Content Models ─────────────────────────────────────────────────

model Content {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title              String
  brief              String
  platform           String
  contentGoal        String
  targetAudience     String
  customAudience     String?
  writingTone        String
  contentLength      String
  customWordCount    Int?
  outputLanguage     String
  ctaType            String?
  hashtagPreference  String?
  customHashtags     String?
  keywords           String?
  wordsToAvoid       String?
  negativeConstraints String?
  emojiEnabled       Boolean  @default(true)
  imageUrl           String?

  generatedContent   String
  status             String   @default("draft") // "draft" | "published"

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("content")
}
